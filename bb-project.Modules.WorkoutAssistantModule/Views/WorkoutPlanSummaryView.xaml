<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://xamarin.com/schemas/2014/forms" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bb_project.Modules.WorkoutAssistantModule.Views.WorkoutPlanSummaryView">
  <ContentView.Content>
      
      <!--//TODO: display workouts-->
        <StackLayout Orientation="Vertical">

            <ListView ItemsSource="{Binding WorkoutPlans}"  VerticalOptions="Center"  SelectionMode="Single" SelectedItem="{Binding SelectedWorkoutPlan, Mode=TwoWay}"  >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <StackLayout Orientation="Horizontal" >
                                <CheckBox IsChecked="{Binding IsActive}" />
                                <Label Text="{Binding Name}" VerticalOptions="Center" FontSize="30" FontAttributes="Bold"/>
                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Button Text="Mostra esercizi"
                    Command="{Binding ShowWorkoutExercisesCommand}" />
        </StackLayout>
    </ContentView.Content>
</ContentView>