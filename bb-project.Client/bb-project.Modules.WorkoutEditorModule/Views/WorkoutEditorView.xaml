             xmlns:ctrl="http://xamarin.com/schemas/2020/toolkit" xmlns:ai="clr-namespace:AiForms.Renderers;assembly=CollectionView"
             x:Class="bb_project.Client.Modules.WorkoutEditorModule.Views.WorkoutEditorView"
             x:Name="root" >

    <StackLayout Orientation="Vertical" BackgroundColor="Red">
        <ListView 
            ItemsSource="{Binding Items,Mode=OneWay, UpdateSourceEventName=PropertyChanged}" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Button BorderWidth="150" BorderColor="Fuchsia" Text="{Binding Name}" Command="{Binding BindingContext.NextStateCommand, Source={x:Reference root}}" CommandParameter="{Binding}"/>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Text="BACK" Command="{Binding PreviousStateCommand}"/>
