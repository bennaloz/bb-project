<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://xamarin.com/schemas/2014/forms" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bb_project.Client.Modules.WorkoutEditorModule.Views.EditorView">
  <ContentView.Content>
      <StackLayout Orientation="Vertical" x:Name="root">
            <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            BorderColor="Black"
                           BackgroundColor="SkyBlue"
                            CornerRadius="10"
                           HasShadow="True">
                            <Editor Text="{Binding Name, Mode=TwoWay}" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="Salva" Command="{Binding SaveCommand}"/>
            <Button Text="Annulla" Command="{Binding BackCommand}"/>
        </StackLayout>
  </ContentView.Content>
</ContentView>